# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit real .env files)
.env
.env.local
.env.*.local
# Keep .env.example for documentation
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt
.Claude
.claude

server.log
# Skills directory
/skills/
/.zscripts/

# Database files (should never be committed)
/db/*.db
/db/*.db-journal
/db/*.db-wal
/db/*.db-shm

# Upload directory (contains sensitive legal documents)
/upload/

# Download directory (contains generated assets)
/download/

# Lock files (keep bun.lock, remove package-lock.json to avoid conflicts)
package-lock.json
bun.lock

# Non-project files
/examples/
/mini-services/
Caddyfile
worklog.md
.zscripts/
claude.md